<Window x:Class="OneNoteMarkdownExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OneNoteMarkdownExporter"
        xmlns:models="clr-namespace:OneNoteMarkdownExporter.Models"
        mc:Ignorable="d"
        Title="OneNote to Markdown Exporter" Height="600" Width="900" WindowState="Maximized">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left Column: Notebook Tree -->
        <TextBlock Text="Select Notebooks/Sections to Export:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TreeView x:Name="NotebookTree" Grid.Row="1" Margin="0,0,10,0">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type models:OneNoteItem}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding Name}"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
        <Button x:Name="RefreshButton" Content="Refresh Notebooks" Grid.Row="2" Margin="0,5,10,0" Click="RefreshButton_Click"/>

        <!-- Right Column: Configuration & Logs -->
        <Grid Grid.Column="1" Grid.Row="0" Grid.RowSpan="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                    <TextBlock Text="Output Directory:" FontWeight="Bold"/>
                    <Grid Margin="0,5,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputPathBox" IsReadOnly="True" Text=""/>
                        <Button Content="..." Grid.Column="1" Width="30" Margin="5,0,0,0" Click="BrowseButton_Click"/>
                    </Grid>

                    <TextBlock Text="Assets Folder:" FontWeight="Bold"/>
                    <Grid Margin="0,5,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AssetsPathBox" Text=""/>
                        <Button x:Name="BrowseAssetsButton" Content="..." Grid.Column="1" Width="30" Margin="5,0,0,0" Click="BrowseAssetsButton_Click"/>
                    </Grid>

                    <TextBlock Text="Asset Organization:" FontWeight="Bold"/>
                    <ComboBox x:Name="AssetOrganizationBox" SelectedIndex="0" Margin="0,5,0,5" SelectionChanged="AssetOrganizationBox_SelectionChanged">
                        <ComboBoxItem Content="Centralized assets folder"/>
                        <ComboBoxItem Content="Assets folder per notebook"/>
                        <ComboBoxItem Content="Assets folder per section"/>
                        <ComboBoxItem Content="Assets folder per page"/>
                    </ComboBox>
                    <TextBlock x:Name="AssetOrganizationPreviewText" TextWrapping="Wrap" Foreground="#666666" FontSize="11" Margin="0,0,0,10"/>

                    <GroupBox Margin="0,0,0,10">
                        <GroupBox.Header>
                            <TextBlock Text="Export Options" FontWeight="Bold"/>
                        </GroupBox.Header>
                        <Grid Margin="8,6,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,8">
                                <CheckBox x:Name="ExpandCollapsedBox" Content="Try to expand collapsed paragraphs" IsChecked="True" FontWeight="Normal" Margin="0,0,0,2"/>
                                <TextBlock Text="Works only for writable notebooks." TextWrapping="Wrap" Foreground="#666666" FontSize="11" Margin="22,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                <CheckBox x:Name="OverwriteExistingBox" Content="Overwrite existing files" IsChecked="True" FontWeight="Normal" Margin="0,0,0,2"/>
                                <TextBlock Text="Keeps repeated exports in sync." TextWrapping="Wrap" Foreground="#666666" FontSize="11" Margin="22,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,8">
                                <CheckBox x:Name="LintMarkdownBox" Content="Apply Markdown linting" IsChecked="True" FontWeight="Normal" Margin="0,0,0,2"/>
                                <TextBlock Text="Runs bundled markdownlint-cli after conversion." TextWrapping="Wrap" Foreground="#666666" FontSize="11" Margin="22,0,0,4"/>
                                <Button x:Name="ConfigureLintingButton" Content="Edit .markdownlint.json..." Click="ConfigureLinting_Click"
                                        HorizontalAlignment="Left" Margin="22,0,0,0" Padding="8,2" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                <CheckBox x:Name="PreserveDatesBox" Content="Preserve OneNote dates as file timestamps" IsChecked="True" FontWeight="Normal" Margin="0,0,0,2"/>
                                <TextBlock Text="Sets .md Created and Modified dates from OneNote. Does not change Markdown content." TextWrapping="Wrap" Foreground="#666666" FontSize="11" Margin="22,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,8">
                                <CheckBox x:Name="FontColorsBox" Content="Preserve font colors" IsChecked="False" FontWeight="Normal" Margin="0,0,0,2"/>
                                <TextBlock Text="Writes text colors as inline HTML spans." TextWrapping="Wrap" Foreground="#666666" FontSize="11" Margin="22,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                                <CheckBox x:Name="YamlMetadataBox" Content="Add YAML front matter metadata" IsChecked="False" FontWeight="Normal" Margin="0,0,0,2"/>
                                <TextBlock Text="Adds created and updated dates to the top of each Markdown file." TextWrapping="Wrap" Foreground="#666666" FontSize="11" Margin="22,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- Selection status indicator -->
                    <Border x:Name="SelectionStatusBorder" Background="#FFF3CD" BorderBrush="#FFECB5" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SelectionStatusIcon" Text="⚠" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SelectionStatusText" Text="Select notebooks, sections, or pages from the tree to export" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ExportButton" Content="Start Export" Height="32" Click="ExportButton_Click" FontWeight="Bold" FontSize="13" Margin="0,0,5,0" IsEnabled="False"/>
                        <Button x:Name="StopButton" Content="Stop Export" Grid.Column="1" Height="32" Click="StopButton_Click" FontWeight="Bold" FontSize="13" IsEnabled="False" Margin="5,0,0,0"/>
                    </Grid>

                    <TextBlock Text="Progress:" FontWeight="Bold" Margin="0,12,0,5"/>
                    <ProgressBar x:Name="ExportProgressBar" Height="20" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ExportStatusText" Text="Ready." FontWeight="SemiBold" Margin="0,0,0,10"/>
                </StackPanel>

            <TabControl x:Name="ExportLogTabs" Grid.Row="1">
                <TabItem x:Name="AllLogsTab" Header="Logs">
                    <TextBox x:Name="LogBox" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas"/>
                </TabItem>
                <TabItem x:Name="FailureLogTab" Header="Failures (0)">
                    <TextBox x:Name="FailureLogBox" Text="No failures." TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
